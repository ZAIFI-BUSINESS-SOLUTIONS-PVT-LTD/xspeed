# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost/xspeed_db

# JWT
SECRET_KEY=your-strong-random-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24

# Razorpay — get keys from dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# SMTP email — leave blank to disable (emails log to console instead)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@xspeed.in
